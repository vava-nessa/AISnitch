{
  "name": "@aisnitch/client",
  "version": "0.2.13",
  "description": "Lightweight TypeScript SDK to consume the AISnitch WebSocket event stream — auto-reconnect, Zod parsing, session tracking, filters, and human-readable helpers.",
  "keywords": [
    "aisnitch",
    "ai",
    "agent",
    "websocket",
    "client",
    "sdk",
    "claude-code",
    "opencode",
    "monitoring"
  ],
  "author": "Vanessa Depraute (https://github.com/vava-nessa)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vava-nessa/AISnitch/tree/main/packages/client#readme",
  "bugs": {
    "url": "https://github.com/vava-nessa/AISnitch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vava-nessa/AISnitch.git",
    "directory": "packages/client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf coverage dist",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
